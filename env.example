# ============================================================
# LUNEX — Environment Variables
# Copy to .env for local dev. On Railway: set in Variables tab
# ============================================================

# Supabase — supabase.com → project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_SECRET=generate_64_char_hex_here
ADMIN_SECRET=another_random_secret_here

# Discord — discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id

# NOWPayments — nowpayments.io/api-keys
NOWPAYMENTS_API_KEY=your_api_key
NOWPAYMENTS_IPN_KEY=your_ipn_secret

# Railway sets these automatically — do NOT set manually
# PORT=8080
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
